{
    "version": 3,
    "settings": {
        "appearanceTools": true,
         "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true,
            "units": ["px", "em", "rem", "vh", "vw", "%"]
        },
        "useRootPaddingAwareAlignments": true,
        "color": {
            "custom": true,
            "palette": [
                {
                    "slug": "halloween-orange",
                    "color": "#f97316",
                    "name": "Halloween Orange"
                },
                {
                    "slug": "halloween-dark",
                    "color": "#0f172a",
                    "name": "Halloween Dark"
                }
            ]
        },
        "layout": {
            "contentSize": "800px",
            "wideSize": "1200px"
        },
        "blocks": {
            "core/image": {
                "spacing": {
                    "margin": true,
                    "padding": true
                },
                "typography": {
                    "customFontSize": true
                }
            }
        }
    }
}